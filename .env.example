# Сервер
PORT=5000
NODE_ENV=development

# MongoDB (используйте MongoDB Atlas или локальный сервер)
MONGO_URI=mongodb://localhost:27017/yoga-studio

# Email (для контактной формы)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=info@harmony-yoga.ru

# Stripe (получите на https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
FRONTEND_URL=http://localhost:5000

# Цены Stripe (создайте в Stripe Dashboard и подставьте ID)
STRIPE_PRICE_1=price_1xxx # Разовое занятие
STRIPE_PRICE_2=price_2xxx # Абонемент 8 занятий
STRIPE_PRICE_3=price_3xxx # Безлимит
STRIPE_PRICE_4=price_4xxx # Годовой
